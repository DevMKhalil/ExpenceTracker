@page
@model IndexModel
@{
    ViewData["Title"] = Localizer["Title"];
}

<div class="mb-4">
    <h2 class="fw-bold">@Localizer["WelcomeMessage"]</h2>
</div>

<div class="row mb-4">
    <!-- Daily Total -->
    <div class="col-md-4 mb-3">
        <div class="card h-100 border-0 shadow-sm bg-primary text-white">
            <div class="card-body">
                <h5 class="card-title opacity-75">@SharedLocalizer["DailyTotal"]</h5>
                <h2 class="display-6 fw-bold mb-0">@Model.DailyTotal.ToString("N2")</h2>
            </div>
        </div>
    </div>
    
    <!-- Monthly Total -->
    <div class="col-md-4 mb-3">
        <div class="card h-100 border-0 shadow-sm bg-success text-white">
            <div class="card-body">
                <h5 class="card-title opacity-75">@SharedLocalizer["MonthlyTotal"]</h5>
                <h2 class="display-6 fw-bold mb-0">@Model.MonthlyTotal.ToString("N2")</h2>
            </div>
        </div>
    </div>

    <!-- Pending Total -->
    <div class="col-md-4 mb-3">
        <div class="card h-100 border-0 shadow-sm bg-surface" style="border: 2px dashed var(--bs-warning) !important;">
            <div class="card-body">
                <h5 class="card-title text-muted">@SharedLocalizer["PendingTotal"]</h5>
                <h2 class="display-6 fw-bold mb-0 text-warning">@Model.PendingTotal.ToString("N2")</h2>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-0 pt-4 pb-0">
                <h5 class="fw-bold mb-0">@SharedLocalizer["ByBadge"]</h5>
            </div>
            <div class="card-body">
                @if (Model.BadgeBreakdown == null || Model.BadgeBreakdown.Count == 0)
                {
                    <div class="text-center text-muted p-4">
                        @SharedLocalizer["NoData"]
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var item in Model.BadgeBreakdown)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center border-0 px-0 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <span class="badge-pill shadow-sm" style="background-color: @item.BadgeColor; width: 16px; height: 16px; display: inline-block; padding: 0;"></span>
                                    <span class="fw-medium">@item.BadgeName</span>
                                </div>
                                <span class="fw-bold font-monospace">@item.Total.ToString("N2")</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
