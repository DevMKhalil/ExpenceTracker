@page
@model ErrorModel
@{
    ViewData["Title"] = "خطأ - Error";
}

<div class="card border-danger shadow-sm mt-5 text-center">
    <div class="card-body py-5">
        <h1 class="text-danger display-4 mb-4"><i class="bi bi-exclamation-triangle"></i></h1>
        <h2 class="text-danger mb-3">عذراً، حدث خطأ أثناء معالجة طلبك.</h2>
        <p class="text-muted mb-4">Sorry, an error occurred while processing your request.</p>
        
        @if (Model.ShowRequestId)
        {
            <div class="alert alert-secondary d-inline-block text-start mb-4">
                <strong>Request ID:</strong> <code>@Model.RequestId</code>
            </div>
        }
        
        <div>
            <a asp-page="/Index" class="btn btn-primary px-4">رجوع إلى لوحة القيادة (Go to Dashboard)</a>
        </div>
    </div>
</div>
