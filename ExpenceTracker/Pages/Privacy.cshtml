@page
@model PrivacyModel
@{
    ViewData["Title"] = SharedLocalizer["PrivacyTitle"];
}

<div class="card border-0 shadow-sm mt-4">
    <div class="card-body p-4">
        <h2 class="card-title fw-bold text-primary mb-4">@SharedLocalizer["PrivacyTitle"]</h2>
        
        <div class="alert alert-info border-0 bg-info bg-opacity-10 mb-4">
            <h5 class="alert-heading text-info">@SharedLocalizer["PrivacyHeadline"]</h5>
            <p class="mb-0">@SharedLocalizer["PrivacyBody"]</p>
        </div>

        <h4 class="mt-4">@SharedLocalizer["PrivacyStorageTitle"]</h4>
        <p>@SharedLocalizer["PrivacyStorageBody"]</p>
    </div>
</div>
